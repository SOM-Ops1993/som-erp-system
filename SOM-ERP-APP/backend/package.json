{
  "name": "som-erp-backend",
  "version": "2.0.0",
  "description": "SOM ERP Backend",
  "main": "src/server.js",
  "type": "module",
  "scripts": {
    "dev": "node --watch src/server.js",
    "start": "node src/server.js",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:push": "prisma db push --accept-data-loss",
    "db:post-migrate": "psql %DATABASE_URL% -f prisma/migrations/001_setup.sql"
  },
  "dependencies": {
    "@fastify/cors": "^9.0.1",
    "@fastify/multipart": "^8.3.0",
    "@fastify/static": "^7.0.4",
    "@prisma/client": "^5.14.0",
    "dayjs": "^1.11.11",
    "dotenv": "^16.4.5",
    "fastify": "^4.28.1",
    "pdfkit": "^0.15.0",
    "qrcode": "^1.5.4",
    "xlsx": "^0.18.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "pino-pretty": "^13.1.3",
    "prisma": "^5.14.0"
  }
}
